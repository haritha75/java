import java.util.Scanner;
import java.lang.*;
import java.io.*;

/* Name of the class has to be "Main" only if the class is public. */
class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
			Scanner sc = new Scanner(System.in);
		int T = sc.nextInt();
		while(T!=0){

		int X = sc.nextInt();   //2
		int Y = sc.nextInt();   //4
		int Z = sc.nextInt();   //1
		int a = Y / X;  //  4 / 2
		Z = Math.max(Z , a);
		int b = Z - a;
		System.out.println(b);
		
		T--;
		}
	}
}
