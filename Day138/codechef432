import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		// your code goes here
		Scanner sc = new Scanner(System.in);
		int x = sc.nextInt();
		for(int i =0;i<x;i++){
		    int y = sc.nextInt();
		    if(y>=4){
		        System.out.println(3*y-3);
		    }else{
		        System.out.println(-1);
		    }
		}
		

	}
}
