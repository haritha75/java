import java.util.*;

class Main {
    public static void main(String args[]) {
        Scanner sc = new Scanner(System.in);
        int T = sc.nextInt();

        while (T-- > 0) {
            int N = sc.nextInt();
            int cows = N / 4;
            int remainder = N % 4;
            
            int minAnimals = cows + (remainder > 0 ? 1 : 0);
            System.out.println(minAnimals);
        }
    }
}
