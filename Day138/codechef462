import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		// your code goes here
        Scanner sc = new Scanner(System.in);
        int t= sc.nextInt();
        while(t-->0){
            int a= sc.nextInt();
            System.out.println( (a%5==0 || a%10==0) ? a/10+(a%10)/5 : "-1");
        }
	}
}
